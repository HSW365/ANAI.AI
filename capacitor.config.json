{
	"appId": "com.anai.app",
	"appName": "Anai.ai",
	"webDir": "dist/public",
	"server": {
		"url": "https://anaiai.co",
		"cleartext": false,
		"androidScheme": "https"
	},
	"ios": {
		"contentInset": "always",
		"scrollEnabled": true,
		"backgroundColor": "#0a0a0a",
		"preferredContentMode": "mobile",
		"limitsNavigationsToAppBoundDomains": true
	},
	"plugins": {
		"SplashScreen": {
			"launchShowDuration": 2000,
			"backgroundColor": "#0a0a0a",
			"showSpinner": false,
			"splashFullScreen": true,
			"splashImmersive": true
		},
		"StatusBar": {
			"style": "dark",
			"backgroundColor": "#0a0a0a"
		}
	},
	"packageClassList": []
}
